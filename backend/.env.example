# VulnGuard AI — Environment Variables
# Copy this file to .env and fill in your values before running.

# Flask secret key (use a long random string in production)
SECRET_KEY=change-me-in-production-32chars+

# JWT signing secret (different from SECRET_KEY)
JWT_SECRET=change-me-jwt-secret-32chars+

# JWT expiry in hours
JWT_EXPIRES_HOURS=12

# SQLite path (default: backend/instance/vulnguard.db) — change for Postgres etc.
# DATABASE_URL=sqlite:///instance/vulnguard.db

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Scanner limits
MAX_CRAWL_PAGES=25
MAX_CRAWL_DEPTH=3
REQUEST_TIMEOUT=8
CONCURRENT_REQUESTS=6
RATE_LIMIT_DELAY=0.15

# Set to "1" to enable Flask debug mode (NEVER in production)
FLASK_DEBUG=0
